    {
      "key": "customize_head",
      "value": "<style>\n/* 确保选择器能匹配到实际的图标 */\n.file-icon img {\n    width: 80px !important;  \n    height: 80px !important; \n}\n\n.file-icon i {\n    font-size: 80px !important;  \n}\n</style>\n",
      "help": "",
      "type": "text",
      "options": "",
      "group": 4,
      "flag": 1,
      "index": 0
    },
    {
      "key": "customize_body",
      "value": "<script>\nwindow.onload = function() {\n    // 获取所有的文件图标\n    let icons = document.querySelectorAll(\".file-icon img\");\n\n    // 遍历每个图标并调整其大小\n    icons.forEach(function(icon) {\n        icon.style.width = \"80px\";   // 设置图标宽度为 80px\n        icon.style.height = \"80px\";  // 设置图标高度为 80px\n    });\n\n    // 如果图标是字体图标，例如 FontAwesome\n    let fontIcons = document.querySelectorAll(\".file-icon i\");\n\n    fontIcons.forEach(function(icon) {\n        icon.style.fontSize = \"80px\";  // 设置字体图标的大小为 80px\n    });\n};\n</script>\n",
      "help": "",
      "type": "text",
      "options": "",
      "group": 4,
      "flag": 1,
